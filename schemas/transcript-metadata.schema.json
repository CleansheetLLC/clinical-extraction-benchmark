{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cleansheet-llc/clinical-extraction-benchmark/schemas/transcript-metadata.schema.json",
  "title": "Transcript Metadata",
  "description": "Metadata accompanying each transcript in the benchmark.",
  "type": "object",
  "required": ["id", "language", "workflow", "source", "verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{2}-[a-z]+-[0-9]{3}$",
      "description": "Unique ID: {lang}-{workflow}-{sequence}. Example: en-soap-001"
    },
    "language": {
      "type": "string",
      "enum": ["en", "de", "fr", "es", "vi", "zh", "pl"],
      "description": "ISO 639-1 language code"
    },
    "workflow": {
      "type": "string",
      "enum": [
        "general", "soap", "hp", "emergency", "samplers",
        "intake", "followup", "discharge", "procedure",
        "radiology", "lab_review", "cardiology", "neurology",
        "pediatrics", "icu", "respiratory", "consult",
        "progress", "recommendations", "handoff", "dialogue"
      ]
    },
    "source": {
      "type": "string",
      "enum": ["original", "multimed", "n2c2", "united-medsyn", "contributed"],
      "description": "Where the transcript came from"
    },
    "verified": {
      "type": "boolean",
      "description": "Has the transcript been verified against audio (if audio exists)?"
    },
    "audio_file": {
      "type": ["string", "null"],
      "deprecated": true,
      "description": "DEPRECATED. Single audio path. Superseded by audio_files[]. Retained so legacy meta files continue to validate during migration."
    },
    "audio_files": {
      "type": "array",
      "description": "All audio takes recorded for this transcript. Empty array = no audio yet. Order is submission order.",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repo-relative path, e.g. audio/en/en-soap-001/20260514T193045_7a8b9c1d.m4a"
          },
          "contributor": {
            "type": ["string", "null"],
            "description": "Contributor name as submitted, or 'anonymous'/'unknown'"
          },
          "dialect": {
            "type": ["string", "null"],
            "description": "BCP-47 dialect tag, e.g. en-US, de-DE"
          },
          "mic_label": {
            "type": ["string", "null"],
            "description": "Device label from MediaDevices, e.g. 'Built-in Microphone'"
          },
          "noise_condition": {
            "type": ["string", "null"],
            "enum": ["quiet-room", "moderate-background", "simulated-hospital", null]
          },
          "duration_seconds": {
            "type": ["number", "null"],
            "description": "Duration in seconds"
          },
          "submitted_at": {
            "type": ["string", "null"],
            "description": "ISO-8601 timestamp of original submission"
          },
          "source_blob": {
            "type": ["string", "null"],
            "description": "Original blob name in benchmark-audio container (used for ingest idempotency)"
          },
          "verified": {
            "type": "boolean",
            "description": "Has a human reviewed this take?"
          }
        }
      }
    },
    "annotation_file": {
      "type": "string",
      "description": "Relative path to the expected FHIR Bundle"
    },
    "specialty": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Clinical specialties represented (e.g., ['cardiology', 'internal-medicine'])"
    },
    "entity_counts": {
      "type": "object",
      "description": "Expected entity counts by FHIR resource type (for quick reference)",
      "properties": {
        "Condition": { "type": "integer" },
        "MedicationRequest": { "type": "integer" },
        "MedicationStatement": { "type": "integer" },
        "Observation": { "type": "integer" },
        "AllergyIntolerance": { "type": "integer" },
        "Procedure": { "type": "integer" },
        "ServiceRequest": { "type": "integer" },
        "FamilyMemberHistory": { "type": "integer" }
      }
    },
    "annotators": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Who created/verified the FHIR annotation"
    },
    "difficulty": {
      "type": "string",
      "enum": ["simple", "moderate", "complex"],
      "description": "Relative extraction difficulty"
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes about this scenario"
    }
  }
}
